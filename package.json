{
  "name": "asimov-app",
  "productName": "Asimov",
  "version": "3.4.0",
  "description": "Asimov — App de escritorio del ERP Bartez Tecnología.",
  "repository": {
    "type": "git",
    "url": "https://github.com/equazin/asimov-app.git"
  },
  "author": {
    "name": "Bartez Tecnología",
    "email": "ventas@bartez.com.ar"
  },
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.js",
    "dev": "npm run build && cross-env BARTEZ_DEV=1 electron .",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "smoke-test": "npm run build && node scripts/smoke-test.js",
    "release": "npm run build && electron-builder --publish always",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2"
  }
}
